# ============================================
# Xcleaners — Environment Configuration
# ============================================
# Copy to .env and fill in actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# Database & Cache
# --------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/xcleaners
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------
# Security
# --------------------------------------------
SECRET_KEY=your-secret-key-here-CHANGE-IN-PRODUCTION
ENCRYPTION_KEY=
APP_URL=

# --------------------------------------------
# Xcleaners Service
# --------------------------------------------
XCLEANERS_PORT=8003
XCLEANERS_CORS_ORIGINS=http://localhost:3000,http://localhost:8003
XCLEANERS_DEFAULT_PLAN=basic
XCLEANERS_AUTO_SCHEDULE_TIME=18:00

# --------------------------------------------
# Sprint D Track A — Recurring Generator Cron
# --------------------------------------------
# HMAC secret for /api/v1/clean/internal/recurring/generate-window
# Generate: openssl rand -hex 32
INTERNAL_CRON_SECRET=change-me-use-openssl-rand-hex-32

# --------------------------------------------
# Stripe (Billing)
# --------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --------------------------------------------
# Google OAuth
# --------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --------------------------------------------
# Twilio (SMS Notifications)
# --------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --------------------------------------------
# Web Push (VAPID)
# --------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@xcleaners.app

# --------------------------------------------
# Debug
# --------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
