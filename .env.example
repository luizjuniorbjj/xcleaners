# ============================================
# Xcleaners — Environment Configuration
# ============================================
# Copy to .env and fill in actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# Database & Cache
# --------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/xcleaners
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------
# Security
# --------------------------------------------
SECRET_KEY=your-secret-key-here-CHANGE-IN-PRODUCTION
ENCRYPTION_KEY=
APP_URL=

# --------------------------------------------
# Xcleaners Service
# --------------------------------------------
XCLEANERS_PORT=8003
XCLEANERS_CORS_ORIGINS=http://localhost:3000,http://localhost:8003
XCLEANERS_DEFAULT_PLAN=basic
XCLEANERS_AUTO_SCHEDULE_TIME=18:00

# --------------------------------------------
# Sprint D Track A — Recurring Generator Cron
# --------------------------------------------
# HMAC secret for /api/v1/clean/internal/recurring/generate-window
# Generate: openssl rand -hex 32
INTERNAL_CRON_SECRET=change-me-use-openssl-rand-hex-32

# --------------------------------------------
# Stripe (Billing)
# --------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --------------------------------------------
# Google OAuth
# --------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --------------------------------------------
# Twilio (SMS Notifications)
# --------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --------------------------------------------
# Web Push (VAPID)
# --------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@xcleaners.app

# --------------------------------------------
# AI / Chat (added 2026-04-20 — AI Turbo Sprint)
# --------------------------------------------
# Provider: openai | anthropic | proxy
AI_PROVIDER=openai

# OpenAI (motor primario do chat em producao)
OPENAI_API_KEY=
AI_MODEL_PRIMARY=gpt-4.1-mini
AI_MODEL_FALLBACK=gpt-4.1-mini
AI_MODEL_EXTRACTION=gpt-4.1-mini

# Anthropic (fallback opcional)
ANTHROPIC_API_KEY=

# Proxy OpenAI-compatible (opcional, ex. clawtobusiness)
AI_PROXY_URL=

# Content Moderation (OpenAI Moderation API — gratuita)
MODERATION_ENABLED=true
MODERATION_MODEL=omni-moderation-latest

# Security gates fail policy (Smith H-1 2026-04-20):
# true = falhas em moderation/ratelimit bloqueiam request (production).
# false = fail-open (dev local sem Redis/OpenAI).
GATES_FAIL_CLOSED=true

# --------------------------------------------
# Evolution API (WhatsApp — opcional, canal fica disabled se vazio)
# --------------------------------------------
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=xcleaners
EVOLUTION_WEBHOOK_SECRET=

# --------------------------------------------
# WhatsApp Channel Config Source (HIGH-1.2 feature flag)
# --------------------------------------------
# Controls _resolve_business config source in app/modules/cleaning/routes/whatsapp_routes.py:
#   - 'env' (default, safe): legacy env-based config (pre-HIGH-1.2 behavior — uses
#                            EVOLUTION_INSTANCE_NAME + EVOLUTION_WEBHOOK_SECRET above)
#   - 'db':                  DB-first from business_channels with env fallback
#                            (per-business persistence, enables multi-business WhatsApp)
#
# Two-phase rollout strategy:
#   1. Deploy code with WHATSAPP_CONFIG_SOURCE=env (zero impact, legacy preserved)
#   2. Validate webhook continues responding (curl /status, smoke E2E)
#   3. Flip to WHATSAPP_CONFIG_SOURCE=db in controlled window with logs monitored
#   4. Rollback if needed: flip back to 'env' for instant revert (no redeploy)
WHATSAPP_CONFIG_SOURCE=env

# --------------------------------------------
# Debug
# --------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
